#: ./share/applications/org.mageia.manafirewall.desktop
msgctxt "GenericName"
msgid "Frontend to firewalld for firewall configuration"
msgstr "Interfața firewalld pentru configurarea firewall-ului"

#: ./share/applications/org.mageia.manafirewall.desktop
msgctxt "Comment"
msgid "A graphical front end to firewalld for firewall configuration"
msgstr "O interfață grafică a firewalld pentru configurarea firewall-ului"

