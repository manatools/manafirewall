#: tmp.metainfo.xml:7
msgid "manafirewall"
msgstr "manafirewall"

#: tmp.metainfo.xml:8
msgid "A frontend to firewalld using libyui UI abstraction library"
msgstr ""
"O interfața pentru firewalld care folosește libyui, o bibliotecă de "
"abstractizare a interfeței utilizatorului"

#: tmp.metainfo.xml:10
msgid ""
"manafirewall is a firewalld frontend, inspired by firewall-config from "
"firewalld project."
msgstr ""
"manafirewall este un interfață firewalld, inspirată de firewall-config din "
"proiectul firewalld."

#: tmp.metainfo.xml:13
msgid ""
"manafirewall is written in Python 3 and uses libYui, the widget abstraction "
"library written by SUSE, so that it can be run using Qt 5, GTK+ 3, or "
"ncurses interfaces. It provides a frontend for the firewalld dbus firewall "
"manager that can be used in any kind of system environment."
msgstr ""
"manafirewall este scris în Python 3 și folosește libYui, biblioteca de "
"abstractizare a widget-urilor scrisă de SUSE, astfel încât să poată fi rulat"
" folosind interfețele Qt 5, GTK+ 3 sau ncurses. Acesta oferă o interfață "
"pentru firewalld, un manager de dbus firewall, care poate fi utilizată în "
"orice tip de mediu de sistem."
