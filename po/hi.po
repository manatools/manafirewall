#: scripts/manafirewall:28
#, python-format
msgid "%(prog)s %(NL)sversion: %(version)s%(NL)ssite: %(site)s"
msgstr ""

#~ msgid "&Change binding"
#~ msgstr "समूह बदलें (&C)"

#~ msgid "&Load default"
#~ msgstr "डिफ़ॉल्ट लोड करें (&L)"

#~ msgid ""
#~ "<li><b>Masquerading</b>: this option allows to tick or untick a "
#~ "\"Masquerade zone\". Thus this zone is used for masquerading (only for "
#~ "IPv4). (to complete with what is the effect of this addition)</li>"
#~ msgstr ""
#~ "<li><b>आवरण</b>: इस विकल्प द्वारा आप आवरण क्षेत्र चिन्हित या अचिन्हित कर सकते हैं। "
#~ "अतः यह क्षेत्र आवरण के लिए है (केवल आईपी4 हेतु)। (जोड़ने के फलस्वरूप पूर्ण प्रभाव हेतु)</li>"

#~ msgid ""
#~ "<li><b>Port Forwarding</b>: port forwarding is an application of network "
#~ "address translation (NAT) that redirects a communication request from one "
#~ "address and port number combination to another while the packets are "
#~ "traversing the firewall in IPv4 technology. Adding a rule needs to "
#~ "specify a port or port range of incoming requests and its protocol "
#~ "(source) and either a port or range for the destination for local "
#~ "forwarding or address of the destination and optionally port or range if "
#~ "port is changed.</li>"
#~ msgstr ""
#~ "<li><b>अग्रसारित पोर्ट</b>: पोर्ट अग्रसारित प्रक्रिया में नेटवर्क पते अनुवाद (NAT) "
#~ "उपयोग कर फ़ायरवॉल से अंतरित डेटा पैकेट आईपी4 तकनीक में एक पते एवं पोर्ट संख्या संयोजन "
#~ "द्वारा संचार अनुरोध को किसी अन्य की ओर अग्रसर करते हैं। नियम जोड़ने हेतु आवक अनुरोध व "
#~ "प्रोटोकॉल (स्रोत) का पोर्ट या पोर्ट सीमा और लोकल अग्रसारित हेतु लक्षित स्थान का "
#~ "पोर्ट या सीमा या फिर पोर्ट परिवर्तित होने पर लक्षित स्थान का पता व पोर्ट या सीमा "
#~ "निर्दिष्ट करें।</li>"

#~ msgid ""
#~ "<li><b>Ports</b>: this configure option allows to specify a rule with "
#~ "\"Add\" button with a port number or range and a protocol selected in the "
#~ "list tcp, udp, sctp and dccp. The list view displays the already defined "
#~ "rules. A range is defined with a hyphen between two numbers, for example "
#~ "with 80-88. The effect will be that these ports will be open.</li>"
#~ msgstr ""
#~ "<li><b>पोर्ट</b>: इस विन्यास विकल्प द्वारा आप पोर्ट संख्या या सीमा व टीसीपी, "
#~ "यूडीपी, एससीटीपी और डीसीसीपी सूची से चयनित प्रोटोकॉल युक्त नियम को \"जोड़ें \" बटन "
#~ "से निर्दिष्ट कर सकते हैं। सूची दृश्य द्वारा पूर्व परिभाषित नियम प्रदर्शित होंगे। संख्याओं को "
#~ "हायफ़न से पृथक कर सीमा निर्धारित करें, उदाहरण 80-88। इससे ये पोर्ट सक्रिय होंगे।</li>"

#~ msgid ""
#~ "<li><b>Protocols</b>: Here, you can add a protocol among a list of "
#~ "supported protocols by firewalld or to add a specific one that you can "
#~ "name. (to complete with what is the effect of this addition)</li>"
#~ msgstr ""
#~ "<li><b>प्रोटोकॉल</b>: यहाँ आप द्वारा समर्थित प्रोटोकॉल सूची या स्वयं निर्दिष्ट कर "
#~ "प्रोटोकॉल जोड़ सकते हैं। (जोड़ने के फलस्वरूप पूर्ण प्रभाव हेतु)</li>"

#~ msgid ""
#~ "<li><b>Source Ports</b>: this configure option allows to specify a rule "
#~ "with \"Add\" button with a port number or range and a protocol selected "
#~ "in the list tcp, udp, sctp and dccp. The list view displays the already "
#~ "defined rules.(to complete with what is the effect of this addition)</li>"
#~ msgstr ""
#~ "<li><b>स्रोत पोर्ट</b>: इस विन्यास विकल्प द्वारा आप पोर्ट संख्या या सीमा व "
#~ "टीसीपी, यूडीपी, एससीटीपी और डीसीसीपी सूची से चयनित प्रोटोकॉल युक्त नियम को "
#~ "\"जोड़ें \" बटन से निर्दिष्ट कर सकते हैं। सूची दृश्य द्वारा पूर्व परिभाषित नियम प्रदर्शित "
#~ "होंगे। (जोड़ने के फलस्वरूप पूर्ण प्रभाव हेतु)</li>"

#~ msgid ""
#~ "<ul><li><b>Services</b>: when selected in \"Configure\" option, you see a "
#~ "list of services that are predefined. According to the zone, some "
#~ "services are already selected. If you tick or untick a checkbox in regard "
#~ "to a service, the according rules will applying to allow said service on "
#~ "interfaces having the zone. In permanent mode, the configuration is "
#~ "registered directly, but not applied. It will be applied after a "
#~ "firewalld reload.</li>"
#~ msgstr ""
#~ "<ul><li><b>सेवाएँ</b>: \"विन्यास\" विकल्प चयन उपरांत पूर्व परिभाषित सेवाएँ प्रदर्शित "
#~ "होंगी। क्षेत्र अनुसार कुछ सेवाएँ पहले से चयनित भी हो सकती हैं। सेवा संबंधित विकल्प चिन्हित "
#~ "या अचिन्हित करने पर वे नियम उस क्षेत्र के सभी अंतरफलकों पर लागू होंगे। स्थायी मोड में "
#~ "विन्यास लागू नहीं होगी केवल दर्ज होगी। यह firewalld के पुनः आरंभ उपरांत ही लागू "
#~ "होगी।"

#~ msgid ""
#~ "A service is a collection of rules that are applied together in relation "
#~ "to an application. This concept helps to apply what is need for an "
#~ "application by just ticking a checkbox. A lot of services are already "
#~ "defined, but you can add your own for an application which is not "
#~ "provided."
#~ msgstr ""
#~ "सेवा - अनुप्रयोग हेतु लागू नियमों का संग्रह। इस द्वारा अनुप्रयोग हेतु आवश्यक वस्तुएँ चिन्हित "
#~ "कर लागू करें। अधिकतर सेवाएँ पहले से परिभाषित हैं, किसी अनुप्रयोग हेतु अनुपलब्ध होने पर आप "
#~ "स्वयं भी जोड़ सकते हैं।"

#~ msgid "A&dd"
#~ msgstr "जोड़ें (&d)"

#~ msgid ""
#~ "After selecting \"Zones\" for view and one of the Zones, you can "
#~ "configure said zone. There are some parameters for each zone:"
#~ msgstr ""
#~ "\"क्षेत्र\" दृश्य चयन उपरांत आप निर्दिष्ट क्षेत्र विन्यस्त कर सकते हैं। प्रत्येक क्षेत्र हेतु कुछ "
#~ "मापदंड हैं :"

#~ msgid "Credits {}"
#~ msgstr "आभार {}"

#~ msgid "Edit ipsets"
#~ msgstr "आईपी समूह संपादन"

#~ msgid "Edit services"
#~ msgstr "सेवा संपादन"

#~ msgid "Edit zones"
#~ msgstr "क्षेत्र संपादन"

#~ msgid ""
#~ "For a zone, available fields are name, version, short as more descriptive "
#~ "name, and description. A check box allows to activate default target or "
#~ "to select the default behaviour for packets that don't match any rule. "
#~ "Targets are DROP, REJECT or ACCEPT. "
#~ msgstr ""
#~ "क्षेत्र हेतु नाम, संस्करण, संक्षिप्त व विस्तृत नाम, एवं विवरण उपलब्ध हैं। चिन्हित कर आप "
#~ "डिफ़ॉल्ट लक्ष्य सक्रिय या नियम से असंगत डेटा पैकेट हेतु डिफ़ॉल्ट व्यवहार चुन सकते हैं। लक्ष्य "
#~ "हैं निरस्त, अस्वीकृत या स्वीकृत।"

#~ msgid ""
#~ "In view \"Services\", the \"Configure\" button next to the combobox "
#~ "allows to choose a service. Selecting one updates the table with a list "
#~ "of couples Port-Protocol "
#~ msgstr ""
#~ "\"सेवा\" दृश्य में, एकाधिक विकल्प चयन के साथ दिए \"विन्यास\" बटन द्वारा सेवा चुनें। "
#~ "चयन उपरांत तालिका पोर्ट-प्रोटोकॉल संयोजन सूची अपडेट होगी।"

#~ msgid "Lockdown: {}"
#~ msgstr "लॉकडाउन : {}"

#~ msgid ""
#~ "ManaFirewall is part of manatools and it is based on libyui so that it "
#~ "can work using Gtk, Qt or ncurses, i.e. graphical or textual user "
#~ "interfaces."
#~ msgstr ""
#~ "ManaFirewall - manatools का भाग है व libyui आधारित होने के कारण इसे जीटीके, "
#~ "क्यूटी या ncurses यानि चित्रात्मक या लेख युक्त उपयोक्ता अंतरफलकों में कार्यरत करना संभव "
#~ "है।"

#~ msgid ""
#~ "On the left there is the overview of the active bindings. These are the "
#~ "zones, that have a connection, interface or source bound or added to it. "
#~ "Here it is possible to easily change the          zone of these bindings."
#~ msgstr ""
#~ "बायीं ओर सक्रिय समूह का अवलोकन प्रदर्शित है। ये कनेक्शन, अंतरफलक या स्रोत हेतु या जोड़ें "
#~ "गए युक्त क्षेत्र हैं। यहाँ आप सरलता से इन समूहों का क्षेत्र बदल सकते हैं।"

#~ msgid ""
#~ "Permanent mode allows to configure things that are not active "
#~ "immediately. If you want to have changes also in the runtime environment, "
#~ "then either add the changes there also or reload firewalld."
#~ msgstr ""
#~ "स्थायी मोड द्वारा आप वर्तमान में निष्क्रिय वस्तुएँ विन्यस्त कर सकते हैं। कार्यरत वातावरण "
#~ "में परिवर्तन हेतु वहाँ भी परिवर्तन करें या firewalld पुनः लोड करें।"

#~ msgid ""
#~ "Predefined zones are: block - dmz - drop - external - home - home - "
#~ "internal - public - trusted - work"
#~ msgstr ""
#~ "पूर्व परिभाषित क्षेत्र हैं : निरुद्ध - परिधि - निरस्त - बाह्य - होम - होम - आंतरिक - "
#~ "सार्वजनिक - विश्वसनीय - कार्य"

#~ msgid ""
#~ "Runtime mode allows to configure things at runtime. Things changed at "
#~ "runtime will not present at next start up or reloading firewalld, if you "
#~ "want that you need to add those changes in permanent mode also. "
#~ msgstr ""
#~ "कार्यरत मोड द्वारा आप कार्यरत वस्तुएँ विन्यस्त कर सकते हैं। कार्यरत वातावरण के परिवर्तन "
#~ "अगले सिस्टम आरंभ या पुनः लोड उपरांत मौजूद नहीं होंगे, यदि आप ये परिवर्तन स्थायी रूप से "
#~ "चाहते हैं तो इन्हें स्थायी मोड में करें।"

#~ msgid "{}  is a graphical configuration tool for firewalld."
#~ msgstr "{} - firewalld हेतु चित्रात्मक विन्यास साधन है।"
