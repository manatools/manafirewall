#: scripts/manafirewall:28
#, python-format
msgid "%(prog)s %(NL)sversion: %(version)s%(NL)ssite: %(site)s"
msgstr "%(prog)s %(NL)sversioon: %(version)s%(NL)ssait: %(site)s"

#~ msgid "&Change binding"
#~ msgstr "&Muuda seost"

#~ msgid "&Load default"
#~ msgstr "L&aadi vaikeväärtused"

#~ msgid ""
#~ "<li><b>Masquerading</b>: this option allows to tick or untick a "
#~ "\"Masquerade zone\". Thus this zone is used for masquerading (only for "
#~ "IPv4). (to complete with what is the effect of this addition)</li>"
#~ msgstr ""
#~ "<li><b>Maskeerimine</b>: see valik lubab märkida \"maskeerimistsooni\" "
#~ "või selle märke eemaldada. Tegemist on maskeerimiseks.tarvitatava "
#~ "tsooniga (ainult IPv4 puhul). (SIIN TULEB VEEL KIRJA PANNA SELLE MÕjU)</"
#~ "li>"

#~ msgid ""
#~ "<li><b>Port Forwarding</b>: port forwarding is an application of network "
#~ "address translation (NAT) that redirects a communication request from one "
#~ "address and port number combination to another while the packets are "
#~ "traversing the firewall in IPv4 technology. Adding a rule needs to "
#~ "specify a port or port range of incoming requests and its protocol "
#~ "(source) and either a port or range for the destination for local "
#~ "forwarding or address of the destination and optionally port or range if "
#~ "port is changed.</li>"
#~ msgstr ""
#~ "<li><b>Pordiedastus</b>: pordiedastus kujutab endast võrguaadressi "
#~ "teisendamise (NAT) rakendamist, millega sidepäring suunatakse ühelt "
#~ "aadressi ja pordinumbri kombinatssioonilt teisele, mis lubab pakettidel "
#~ "IPv4 tehnoloogiat kasutades läbida tulemüüri. Reegli lisamisel tulrb "
#~ "määrata saabuvate päringute port või pordivahemik ja protokoll "
#~ "(lähtekoht) ning kas kohaliku edastamise või sihtmärgi aadressi  port või "
#~ "pordivahemik, samuti soovi korral port või pordivahemik juhuks, kui port "
#~ "peaks muutuma.</li>"

#~ msgid ""
#~ "<li><b>Ports</b>: this configure option allows to specify a rule with "
#~ "\"Add\" button with a port number or range and a protocol selected in the "
#~ "list tcp, udp, sctp and dccp. The list view displays the already defined "
#~ "rules. A range is defined with a hyphen between two numbers, for example "
#~ "with 80-88. The effect will be that these ports will be open.</li>"
#~ msgstr ""
#~ "<li><b>Pordid</b>: see võimaldab nupule \"Lisa \"klõpsates määrata reegli "
#~ "ühes pordinumbri või -vahemikuga ning loendist - tcp, udp, sctp või dccp "
#~ "- valitava protokolliga. Loendivaates näeb valmisreegleid. Vahemiku "
#~ "määramiseks tuleb kasutada sidekriipsu, näiteks 80-88. The Määramise "
#~ "korral pordid avatakse.</li>"

#~ msgid ""
#~ "<li><b>Protocols</b>: Here, you can add a protocol among a list of "
#~ "supported protocols by firewalld or to add a specific one that you can "
#~ "name. (to complete with what is the effect of this addition)</li>"
#~ msgstr ""
#~ "<li><b>Protokollid</b>: siin saab lisada protokolli juba firewalld "
#~ "toetatavate protokollide loendisse või lisada spetsiifilise protokolli, "
#~ "millele ise nimi anda (millega tegelikult see lisataksegi)</li>"

#~ msgid ""
#~ "<li><b>Source Ports</b>: this configure option allows to specify a rule "
#~ "with \"Add\" button with a port number or range and a protocol selected "
#~ "in the list tcp, udp, sctp and dccp. The list view displays the already "
#~ "defined rules.(to complete with what is the effect of this addition)</li>"
#~ msgstr ""
#~ "<li><b>Lähtepordid</b>: see võimaldab nupule \"Lisa\" klõpsates määrata "
#~ "reegli ühes pordinumbri või -vahemikuga ning loendist - tcp, udp, sctp "
#~ "või dccp - valitava protokolliga. Loendivaates näeb valmisreegleid..</li>"

#~ msgid ""
#~ "<ul><li><b>Services</b>: when selected in \"Configure\" option, you see a "
#~ "list of services that are predefined. According to the zone, some "
#~ "services are already selected. If you tick or untick a checkbox in regard "
#~ "to a service, the according rules will applying to allow said service on "
#~ "interfaces having the zone. In permanent mode, the configuration is "
#~ "registered directly, but not applied. It will be applied after a "
#~ "firewalld reload.</li>"
#~ msgstr ""
#~ "<ul><li><b>Teenused</b>: \"Seadista\" valimisel näeb valmisteenuste "
#~ "loendit. Vastavalt tsoonile on mõned teenused juba valitud. Teenuse "
#~ "juures paikneva märkeruudu märkimisel või sealt märke eemaldamisel "
#~ "rakendatakse vastavaid reegleid lubamaks teenusele liidestes tsooni. "
#~ "Püsirežiimis registreeritakse seadistus otse, aga seda ei rakendata. See "
#~ "rakendatakse alles pärast firewalld taaslaadimist.</li>"

#~ msgid ""
#~ "A service is a collection of rules that are applied together in relation "
#~ "to an application. This concept helps to apply what is need for an "
#~ "application by just ticking a checkbox. A lot of services are already "
#~ "defined, but you can add your own for an application which is not "
#~ "provided."
#~ msgstr ""
#~ "Teenus kujutab endast reegleid, mida saab korraga rakendusele rakendada. "
#~ "Selleks tuleb siin lihtsalt märkekasti märge teha. Hulk teenuseid on juba "
#~ "valmis seatud, aga alati saab lisada oma teenuse rakendusele, mida "
#~ "pakkumises pole."

